<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AssiGnment_5.View.ShoppingItems"
             Title="Shopping Items"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Header row with Profile + Cart buttons -->
        <Grid Grid.Row="0"
              Padding="16,16,16,8"
              ColumnDefinitions="*,Auto,Auto"
              BackgroundColor="White">

            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="🛒 Shopping Items"
                       FontSize="22"
                       FontAttributes="Bold"/>
                <Label Text="Browse and add items to your cart"
                       FontSize="12"
                       TextColor="Gray"/>
            </VerticalStackLayout>

            <!-- Profile button -->
            <Button Grid.Column="1"
                    Text="👤 Profile"
                    FontSize="13"
                    BackgroundColor="#1a73e8"
                    TextColor="White"
                    CornerRadius="16"
                    HeightRequest="36"
                    Padding="10,0"
                    Margin="0,0,6,0"
                    Clicked="OnProfileClicked"/>

            <!-- Cart button -->
            <Button Grid.Column="2"
                    Text="🛍️ Cart"
                    FontSize="13"
                    BackgroundColor="#2e7d32"
                    TextColor="White"
                    CornerRadius="16"
                    HeightRequest="36"
                    Padding="10,0"
                    Clicked="OnViewCartClicked"/>
        </Grid>

        <!-- Divider -->
        <BoxView Grid.Row="1" HeightRequest="1" Color="#e0e0e0"/>

        <!-- Status label -->
        <Label Grid.Row="2"
               x:Name="StatusLabel"
               Text=""
               FontSize="13"
               TextColor="Gray"
               HorizontalOptions="Center"
               Margin="0,6,0,0"/>

        <!-- Loading indicator -->
        <ActivityIndicator Grid.Row="3"
                           x:Name="Loader"
                           IsRunning="False"
                           Color="Green"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
        
        

        <!-- Items list -->
        <CollectionView Grid.Row="3"
                        x:Name="ItemsCollection"
                        Margin="12,8,12,12">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="10"
                                     Margin="0,60,0,0">
                    <Label Text="📦" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="No items found"
                           FontSize="16"
                           TextColor="Gray"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,12"
                           Padding="14"
                           BorderColor="#e0e0e0"
                           CornerRadius="14"
                           BackgroundColor="White"
                           HasShadow="True">
                        
                        <VerticalStackLayout Spacing="6">
                            
                            <!-- IMAGE AREA — Grid allows two overlapping children -->
                            <Grid HeightRequest="220"
                                  BackgroundColor="#f8f8f8">

                                <!-- Placeholder when no image -->
                                <VerticalStackLayout
                                    VerticalOptions="Center"
                                    HorizontalOptions="Center"
                                    Spacing="8"
                                    IsVisible="{Binding HasImage,
                                    Converter={StaticResource InvertBoolConverter}}">
                                    
                                    <Label Text="📷"
                                           FontSize="48"
                                           HorizontalOptions="Center"/>
                                    <Label Text="No image available"
                                           TextColor="#aaa"
                                           FontSize="13"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>

                                <!-- Full image — AspectFit so whole picture is visible -->
                                <Image Source="{Binding ImageUrl}"
                                       Aspect="AspectFit"
                                       HorizontalOptions="Fill"
                                       VerticalOptions="Fill"
                                       IsVisible="{Binding HasImage}"
                                       Margin="12"/>

                            </Grid>

                            <Label Text="{Binding Name}"
                                   FontSize="17"
                                   FontAttributes="Bold"/>

                            <Label Text="{Binding Description}"
                                   FontSize="13"
                                   TextColor="#666"
                                   LineBreakMode="WordWrap"/>

                            <Label Text="{Binding Price, StringFormat='Price: R{0:N2}'}"
                                   FontSize="14"
                                   TextColor="#2e7d32"
                                   FontAttributes="Bold"/>

                            <Label Text="{Binding Quantity, StringFormat='In stock: {0}'}"
                                   FontSize="12"
                                   TextColor="#888"/>

                            <Button Text="Add to Cart"
                                    BackgroundColor="#2e7d32"
                                    TextColor="White"
                                    CornerRadius="20"
                                    HeightRequest="42"
                                    Clicked="OnAddToCartClicked"
                                    CommandParameter="{Binding ItemId}"/>

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>