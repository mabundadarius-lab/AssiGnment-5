<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AssiGnment_5.View.ShoppingItems"
             Title="Shopping Items"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="20,16,20,8" Spacing="4">
            <Label Text="🛒 Shopping Items"
                   FontSize="24"
                   FontAttributes="Bold"/>
            <Label Text="Tap 'Add to Cart' to add items"
                   FontSize="13"
                   TextColor="Gray"/>
        </VerticalStackLayout>

        <!-- View Cart Button -->
        <Button Grid.Row="1"
                Text="View Cart 🛍️"
                Clicked="OnViewCartClicked"
                BackgroundColor="#1a73e8"
                TextColor="White"
                CornerRadius="20"
                HeightRequest="42"
                Margin="16,0,16,10"/>

        <!-- Loading -->
        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Color="Green"/>

        <!-- Items List -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Items}"
                        Margin="12,0,12,12">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="10"
                                     Margin="0,60,0,0">
                    <Label Text="📦" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="No items found" FontSize="16" TextColor="Gray"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <!-- Card wrapper — single child VerticalStackLayout -->
                    <Frame Margin="0,0,0,16"
                           Padding="0"
                           CornerRadius="16"
                           BorderColor="#e0e0e0"
                           BackgroundColor="White"
                           HasShadow="True">

                        <VerticalStackLayout Spacing="0">

                            <!-- IMAGE AREA — Grid allows two overlapping children -->
                            <Grid HeightRequest="220"
                                  BackgroundColor="#f8f8f8">

                                <!-- Placeholder when no image -->
                                <VerticalStackLayout
                                    VerticalOptions="Center"
                                    HorizontalOptions="Center"
                                    Spacing="8"
                                    IsVisible="{Binding HasImage,
                                        Converter={StaticResource InvertBoolConverter}}">
                                    <Label Text="📷"
                                           FontSize="48"
                                           HorizontalOptions="Center"/>
                                    <Label Text="No image available"
                                           TextColor="#aaa"
                                           FontSize="13"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>

                                <!-- Full image — AspectFit so whole picture is visible -->
                                <Image Source="{Binding ImageUrl}"
                                       Aspect="AspectFit"
                                       HorizontalOptions="Fill"
                                       VerticalOptions="Fill"
                                       IsVisible="{Binding HasImage}"
                                       Margin="12"/>

                            </Grid>

                            <!-- DETAILS AREA -->
                            <VerticalStackLayout Padding="16,12,16,16" Spacing="8">

                                <!-- Name -->
                                <Label Text="{Binding Name}"
                                       FontSize="17"
                                       FontAttributes="Bold"/>

                                <!-- Price -->
                                <Label Text="{Binding Price, StringFormat='Price: R{0:N2}'}"
                                       FontSize="15"
                                       TextColor="#2e7d32"
                                       FontAttributes="Bold"/>

                                <!-- Description -->
                                <Label Text="{Binding Description}"
                                       FontSize="13"
                                       TextColor="#666"
                                       LineBreakMode="WordWrap"/>

                                <!-- Divider -->
                                <BoxView HeightRequest="1"
                                         Color="#f0f0f0"
                                         Margin="0,2,0,2"/>

                                <!-- Stock -->
                                <Label Text="{Binding StockDisplay}"
                                       FontSize="13"
                                       TextColor="#888"/>

                                <!-- Add to Cart Button -->
                                <Button Text="🛒  Add to Cart"
                                        BackgroundColor="#2e7d32"
                                        TextColor="White"
                                        CornerRadius="22"
                                        HeightRequest="46"
                                        FontSize="15"
                                        Margin="0,4,0,0"
                                        Clicked="OnAddToCartClicked"
                                        CommandParameter="{Binding ItemId}"/>

                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Frame>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>