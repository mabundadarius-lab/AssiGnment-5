<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AssiGnment_5.View.ShoppingCart"
             Title="My Cart">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="20,16,20,8" Spacing="4">
            <Label Text="🛍️ My Cart"
                   FontSize="24"
                   FontAttributes="Bold"/>
            <Label Text="Items you have added"
                   FontSize="13"
                   TextColor="Gray"/>
        </VerticalStackLayout>

        <!-- Loading indicator -->
        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Color="Green"/>

        <!-- Cart Items -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding CartItems}"
                        Margin="12,0,12,0">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                     Spacing="10" Margin="0,60,0,0">
                    <Label Text="🛒" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="Your cart is empty"
                           FontSize="16" TextColor="Gray"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="#e0e0e0"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14"
                            Margin="0,0,0,10">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                              ColumnDefinitions="*,Auto">

                            <!-- Name -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Name}"
                                   FontSize="17"
                                   FontAttributes="Bold"/>

                            <!-- Qty badge -->
                            <Border Grid.Row="0" Grid.Column="1"
                                    BackgroundColor="#e3f2fd"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="10,4">
                                <Label Text="{Binding QuantityDisplay}"
                                       TextColor="#1565c0"
                                       FontAttributes="Bold"
                                       FontSize="13"/>
                            </Border>

                            <!-- Description -->
                            <Label Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="{Binding Description}"
                                   FontSize="13"
                                   TextColor="Gray"
                                   Margin="0,4,0,2"/>

                            <!-- Price / Subtotal -->
                            <Label Grid.Row="2" Grid.Column="0"
                                   Text="{Binding PriceDisplay}"
                                   FontSize="12"
                                   TextColor="#888"/>
                            <Label Grid.Row="2" Grid.Column="1"
                                   Text="{Binding SubtotalDisplay}"
                                   FontSize="12"
                                   TextColor="#2e7d32"
                                   FontAttributes="Bold"/>

                            <!-- Buttons: Remove One | Remove All -->
                            <Grid Grid.Row="3" Grid.ColumnSpan="2"
                                  ColumnDefinitions="*,*"
                                  Margin="0,8,0,0"
                                  ColumnSpacing="8">

                                <!-- Remove One (-1) -->
                                <Button Grid.Column="0"
                                        Text="− Remove One"
                                        BackgroundColor="#ff7043"
                                        TextColor="White"
                                        CornerRadius="20"
                                        HeightRequest="40"
                                        Clicked="OnRemoveOneClicked"
                                        CommandParameter="{Binding CartId}"/>

                                <!-- Remove All -->
                                <Button Grid.Column="1"
                                        Text="🗑 Remove All"
                                        BackgroundColor="#e53935"
                                        TextColor="White"
                                        CornerRadius="20"
                                        HeightRequest="40"
                                        Clicked="OnRemoveAllClicked"
                                        CommandParameter="{Binding CartId}"/>
                            </Grid>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Bottom Buttons -->
        <VerticalStackLayout Grid.Row="2" Padding="16,8" Spacing="10">
            <Button Text="Clear Cart"
                    Clicked="OnClearCartClicked"
                    BackgroundColor="#e53935"
                    TextColor="White"
                    CornerRadius="25"
                    HeightRequest="48"/>
            <Button Text="← Back to Shopping"
                    Clicked="OnBackToShoppingClicked"
                    BackgroundColor="#1a73e8"
                    TextColor="White"
                    CornerRadius="25"
                    HeightRequest="48"/>
            <Button Text="View Profile"
                    Clicked="OnViewProfileClicked"
                    BackgroundColor="Green"
                    TextColor="White"
                    CornerRadius="25"
                    HeightRequest="48"/>
        </VerticalStackLayout>

    </Grid>
</ContentPage>